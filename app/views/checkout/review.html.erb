<h1>Review Your Order</h1>

<h2>Shipping Information</h2>

<p>
  Name:
  <%= @customer.first_name %>
  <%= @customer.last_name %>
</p>

<p>
  Email:
  <%= @customer.email %>
</p>

<p>
  Address:
  <%= @customer.address %>,
  <%= @customer.city %>,
  <%= @province.name %>,
  <%= @customer.postal_code %>
</p>

<h2>Invoice</h2>

<table class="admin-table">
  <thead>
    <tr>
      <th>Product</th>
      <th>Unit Price</th>
      <th>Quantity</th>
      <th>Item Total</th>
    </tr>
  </thead>

  <tbody>
    <% @cart_items.each do |item| %>
      <tr>
        <td><%= item[:product].name %></td>

        <td>
          <%= number_to_currency(item[:product].price) %>
        </td>

        <td><%= item[:quantity] %></td>

        <td>
          <%= number_to_currency(item[:item_total]) %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="order-totals">
  <p>
    Subtotal:
    <%= number_to_currency(@subtotal) %>
  </p>

  <% if @province.gst_rate.positive? %>
    <p>
      GST
      (<%= number_to_percentage(
        @province.gst_rate * 100,
        precision: 3,
        strip_insignificant_zeros: true
      ) %>):

      <%= number_to_currency(@gst_amount) %>
    </p>
  <% end %>

  <% if @province.pst_rate.positive? %>
    <p>
      <%= @province.code == "QC" ? "QST" : "PST" %>
      (<%= number_to_percentage(
        @province.pst_rate * 100,
        precision: 3,
        strip_insignificant_zeros: true
      ) %>):

      <%= number_to_currency(@pst_amount) %>
    </p>
  <% end %>

  <% if @province.hst_rate.positive? %>
    <p>
      HST
      (<%= number_to_percentage(
        @province.hst_rate * 100,
        precision: 3,
        strip_insignificant_zeros: true
      ) %>):

      <%= number_to_currency(@hst_amount) %>
    </p>
  <% end %>

  <p>
    Total Tax:
    <%= number_to_currency(@tax_amount) %>
  </p>

  <p>
    Grand Total:
    <%= number_to_currency(@total_price) %>
  </p>
</div>

<%= button_to "Place Order",
              checkout_complete_path,
              method: :post,
              data: { turbo: false } %>

<p>
  <%= link_to "Change Address", checkout_path %>
</p>

<p>
  <%= link_to "Back to Cart", cart_path %>
</p>