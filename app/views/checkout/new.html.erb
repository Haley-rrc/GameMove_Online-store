<h1>Checkout</h1>

<%= form_with model: @customer,
              url: checkout_review_path,
              method: :post,
              data: { turbo: false } do |form| %>

  <% if @customer.errors.any? %>
    <ul>
      <% @customer.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  <% end %>

  <p>
    <%= form.label :first_name %>
    <%= form.text_field :first_name, required: true %>
  </p>

  <p>
    <%= form.label :last_name %>
    <%= form.text_field :last_name, required: true %>
  </p>

  <p>
    <%= form.label :email %>
    <%= form.email_field :email, required: true %>
  </p>

  <p>
    <%= form.label :address %>
    <%= form.text_field :address, required: true %>
  </p>

  <p>
    <%= form.label :city %>
    <%= form.text_field :city, required: true %>
  </p>

  <p>
    <%= form.label :postal_code %>
    <%= form.text_field :postal_code,
                        placeholder: "R3C 0V8",
                        required: true %>
  </p>

  <p>
    <%= form.label :province_id, "Province" %>

    <%= form.collection_select(
          :province_id,
          Province.order(:name),
          :id,
          :name,
          { prompt: "Select a province" },
          { required: true }
        ) %>
  </p>

  <%= form.submit "Review Order" %>
<% end %>