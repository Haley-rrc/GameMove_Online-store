<h1>Checkout</h1>

<h2>Customer Information</h2>

<%= form_with model: @user,
              url: checkout_review_path,
              method: :post,
              data: { turbo: false } do |form| %>

  <% if @user.errors.any? %>
    <div class="form-errors">
      <h2>Please fix these errors:</h2>

      <ul>
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-field">
    <%= form.label :first_name %>
    <%= form.text_field :first_name %>
  </div>

  <div class="form-field">
    <%= form.label :last_name %>
    <%= form.text_field :last_name %>
  </div>

  <div class="form-field">
    <%= form.label :email %>
    <%= form.email_field :email %>
  </div>

  <div class="form-field">
    <%= form.label :address %>
    <%= form.text_area :address, rows: 3 %>
  </div>

  <div class="form-field">
    <%= form.label :city %>
    <%= form.text_field :city %>
  </div>

  <div class="form-field">
    <%= form.label :postal_code %>
    <%= form.text_field :postal_code,
                        placeholder: "R3C 0V8" %>
  </div>

  <div class="form-field">
    <%= form.label :province_id, "Province" %>

    <%= form.collection_select(
          :province_id,
          Province.order(:name),
          :id,
          :name,
          prompt: "Select a province"
        ) %>
  </div>

  <div class="form-actions">
    <%= form.submit "Review and Submit Order" %>
  </div>
<% end %>

<h2>Cart Summary</h2>

<table class="admin-table">
  <thead>
    <tr>
      <th>Product</th>
      <th>Quantity</th>
      <th>Item Total</th>
    </tr>
  </thead>

  <tbody>
    <% @cart_items.each do |item| %>
      <tr>
        <td><%= item[:product].name %></td>
        <td><%= item[:quantity] %></td>
        <td><%= number_to_currency(item[:item_total]) %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<h3>
  Subtotal:
  <%= number_to_currency(@subtotal) %>
</h3>

<p>
  <%= link_to "Back to Cart", cart_path %>
</p>