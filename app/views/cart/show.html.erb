<h1>Shopping Cart</h1>

<% if @cart_items.any? %>
  <table class="admin-table">
    <thead>
      <tr>
        <th>Product</th>
        <th>Price</th>
        <th>Quantity</th>
        <th>Item Total</th>
        <th>Remove</th>
      </tr>
    </thead>

    <tbody>
      <% @cart_items.each do |item| %>
        <tr>
          <td>
            <%= link_to item[:product].name,
                        product_path(item[:product]) %>
          </td>

          <td>
            <%= number_to_currency(item[:product].price) %>
          </td>

          <td>
            <%= form_with url: update_cart_item_path(item[:product]),
                          method: :patch,
                          class: "cart-quantity-form" do |form| %>

              <%= form.number_field :quantity,
                                    value: item[:quantity],
                                    min: 1,
                                    max: item[:product].stock_quantity %>

              <%= form.submit "Update" %>
            <% end %>
          </td>

          <td>
            <%= number_to_currency(item[:item_total]) %>
          </td>

          <td>
            <%= button_to "Remove",
                          remove_cart_item_path(item[:product]),
                          method: :delete,
                          data: {
                            turbo_confirm: "Remove this item from the cart?"
                          } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <h2>
    Cart Total:
    <%= number_to_currency(@cart_total) %>
  </h2>

  <p>
    <%= link_to "Continue to Checkout",
                checkout_path,
                class: "checkout-link" %>
  </p>
<% else %>
  <p>Your shopping cart is empty.</p>
<% end %>

<p>
  <%= link_to "Continue Shopping", products_path %>
</p>