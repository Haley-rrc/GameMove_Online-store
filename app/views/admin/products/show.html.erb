<h1><%= @product.name %></h1>

<p>
  Category:
  <%= @product.category.name %>
</p>

<p>
  Description:
  <%= @product.description %>
</p>

<p>
  Price:
  <%= number_to_currency(@product.price) %>
</p>

<p>
  Stock Quantity:
  <%= @product.stock_quantity %>
</p>

<p>
  <%= link_to "Edit Product", edit_admin_product_path(@product) %>
</p>

<p>
  <%= link_to "Back to Admin Products", admin_products_path %>
</p>