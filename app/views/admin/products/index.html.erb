<h1>Admin Product Management</h1>
<p>
  <%= link_to "Add New Product", new_admin_product_path %>
</p>

<table class="admin-table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Category</th>
      <th>Price</th>
      <th>Stock</th>
      <th>Actions</th>
    </tr>
  </thead>

  <tbody>
    <% @products.each do |product| %>
      <tr>
        <td><%= product.name %></td>
        <td><%= product.category.name %></td>
        <td><%= number_to_currency(product.price) %></td>
        <td><%= product.stock_quantity %></td>
        <td>
          <%= link_to "View", admin_product_path(product) %>
          <%= link_to "Edit", edit_admin_product_path(product) %>

          <%= button_to "Delete",
                        admin_product_path(product),
                        method: :delete,
                        data: {
                          turbo_confirm: "Are you sure you want to delete this product?"
                        } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<p>
  <%= link_to "Back to Store", root_path %>
</p>